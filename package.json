{
  "name": "slotsync",
  "scripts": {
    "install:all": "npm install && cd client && npm install && cd ../server && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && node index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
