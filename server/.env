PORT=4000
MANAGER_EMAIL=manager@yourcompany.com

# Zap 1B — sends screening report to manager
ZAPIER_SCREENING_EMAIL_WEBHOOK=your_zap_1b_url_here

# Zap 2A — sends confirmation email to candidate
ZAPIER_CONFIRMED_CANDIDATE=your_zap_2a_url_here

# Zap 2B — sends confirmation summary to manager
ZAPIER_CONFIRMED_MANAGER=your_zap_2b_url_here

# Automation 3 — daily reminders via nodemailer (no Zapier needed)
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
